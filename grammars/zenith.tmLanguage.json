{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Zenith-Lang",
  "scopeName": "source.zenith",
  "fileTypes": ["zl"],
  "patterns": [
    {"include": "#directive"},
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#numbers"},
    {"include": "#booleans"},
    {"include": "#keywords"},
    {"include": "#types"},
    {"include": "#operators"},
    {"include": "#macros"},
    {"include": "#identifiers"}
  ],
  "repository": {
    "directive": {
      "patterns": [{
        "name": "entity.name.tag.directive.zenith",
        "match": "\\.:(?:EN|ES|PT|FR):\\."
      }]
    },
    "comments": {
      "patterns": [
        {"name": "comment.line.number-sign.zenith", "match": "#.*$"},
        {"name": "comment.line.double-slash.zenith", "match": "//.*$"},
        {"name": "comment.block.zenith", "begin": "/\\*", "end": "\\*/"}
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.zenith",
          "begin": "'''",
          "end": "'''"
        },
        {
          "name": "string.quoted.single.zenith",
          "begin": "'",
          "end": "'",
          "patterns": [{
            "name": "constant.character.escape.zenith",
            "match": "\\\\[nrt\\\\'\"]"
          }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {"name": "constant.numeric.hex.zenith", "match": "\\b0x[0-9a-fA-F]+\\b"},
        {"name": "constant.numeric.binary.zenith", "match": "\\b0b[01]+\\b"},
        {"name": "constant.numeric.octal.zenith", "match": "\\b0o[0-7]+\\b"},
        {"name": "constant.numeric.decimal.zenith", "match": "\\b\\d+(\\.\\d+)?\\b"}
      ]
    },
    "booleans": {
      "patterns": [{
        "name": "constant.language.boolean.zenith",
        "match": "(?i)\\b(TRUE|FALSE|VERDADERO|FALSO)\\b"
      }]
    },
    "keywords": {
      "patterns": [{
        "name": "keyword.control.zenith",
        "match": "(?i)\\b(DEFINE|DEFINIR|CONSTANT|CONSTANTE|IF|SI|THEN|ENTONCES|ELSE-IF|SINO-SI|ELSE|SINO|END-IF|FIN-SI|REPEAT|REPETIR|WHILE|MIENTRAS|UNTIL|HASTA|TIMES|VECES|BETWEEN|ENTRE|NEXT-REPEAT|FIN-REPETIR|FOR|PARA|SKIP-REPEAT|SALTAR-REPETIR|EXIT-REPEAT|SALIR-REPETIR|MATCH|COINCIDIR|CASE|CASO|OTHER|OTRO|END-MATCH|FIN-COINCIDIR|WHERE|DONDE|BY|POR|TO|A|OF|DE|INFINITY|WITH|CON|FUNCTION|FUNCION|END-FUNCTION|FIN-FUNCION|CALL|LLAMAR|RETURN|RETORNAR|RETURNS|RETORNA|USING|USANDO|CHANGING|CAMBIANDO|PROGRAM|PROGRAMA|END-PROGRAM|FIN-PROGRAMA|MODULE|MODULO|END-MODULE|FIN-MODULO|IMPORT|IMPORTAR|EXPORT|EXPORTAR|END-EXPORT|FIN-EXPORTAR|AS|COMO|IN|EN|STRUCTURE|ESTRUCTURA|END-STRUCTURE|FIN-ESTRUCTURA|DESTROY|DESTRUIR|TYPE|TIPO|LIKE|DISPLAY|MOSTRAR|INPUT|ENTRADA|LOG|INFO|WARNING|ADVERTENCIA|ERROR|HIDDEN|OCULTO|MASKED|ENMASCARADO|AT|LINE|LINEA|COLUMN|COLUMNA|COLOR|BACKGROUND|FONDO|BOLD|NEGRITA|ITALIC|CURSIVA|UNDERLINE|SUBRAYADO|SPACE|ESPACIO|NEWLINE|NUEVA-LINEA|NL|INTO|HACIA|SEPARATED|SEPARADO|INSERT|INSERTAR|UPDATE|ACTUALIZAR|DELETE|ELIMINAR|FIND|BUSCAR|SORT|ORDENAR|CLEAR|LIMPIAR|FROM|DESDE|ALL|TODO|ASCENDING|ASCENDENTE|DESCENDING|DESCENDENTE|INDEX|INDICE|FIELD|CAMPO|BATCH|LOTE|OPERATION|OPERACION|SYSTEM|SISTEMA|GET|OBTENER|COMPUTE|CALCULAR|COPY|COPIAR|ASSERT|AFIRMAR|STOP|DETENER|SIZE|TAMANO|EMPTY|VACIO|VERSION|AUTHOR|AUTOR|DESCRIPTION|DESCRIPCION|TIME-ZONE|ZONA-HORARIA|READ-KEY|LEER-TECLA|OPEN-FILE|ABRIR-ARCHIVO|CLOSE-FILE|CERRAR-ARCHIVO|TRY|INTENTAR|CATCH|CAPTURAR|FINALLY|FINALMENTE|END-TRY|FIN-INTENTAR|RAISE|LANZAR|ANY|CUALQUIER|NEW|NUEVO)\\b"
      }]
    },
    "types": {
      "patterns": [{
        "name": "entity.name.type.zenith",
        "match": "(?i)\\b(INTEGER|ENTERO|DECIMAL|TEXT|TEXTO|BOOLEAN|BOOLEANO|DATE|FECHA|TIME|HORA|TIMESTAMP|DATETIME|FLOAT|FLOTANTE|CHARACTER|CARACTER|TABLE|TABLA|ROW|FILA|PRIMARY-KEY|CLAVE-PRIMARIA|REQUIRED|REQUERIDO|UNIQUE|UNICO|POSITIVE|POSITIVO|NEGATIVE|NEGATIVO|UNSIGNED|SIN-SIGNO)\\b"
      }]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.zenith",
          "match": "(?i)\\b(AND|Y|OR|O|NOT|NO|CONTAINS|CONTIENE|EQ|NE|LT|GT|LE|GE|IS|MOD|DIV)\\b"
        },
        {
          "name": "keyword.operator.symbol.zenith",
          "match": "(==|<>|!=|<=|>=|<|>|\\+|-|\\*|/|%|\\^|::|\\.\\.|=)"
        }
      ]
    },
    "macros": {
      "patterns": [{
        "name": "entity.name.function.macro.zenith",
        "match": "(?i)\\b(SUM|SUMA|COUNT|CONTAR|AVERAGE|PROMEDIO|MIN|MAX|FORMAT-DATA|EXPORT-DATA)!"
      }]
    },
    "identifiers": {
      "patterns": [{
        "name": "variable.other.zenith",
        "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*\\b"
      }]
    }
  }
}
