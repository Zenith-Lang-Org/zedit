{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Zymbol-Lang",
  "scopeName": "source.zymbol",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#control-flow" },
    { "include": "#io-operators" },
    { "include": "#function-operators" },
    { "include": "#collection-operators" },
    { "include": "#module-operators" },
    { "include": "#data-operators" },
    { "include": "#format-expressions" },
    { "include": "#base-literals" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zymbol",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.zymbol",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.zymbol",
              "match": "\\\\(n|t|\"|'|\\\\|u\\{[0-9A-Fa-f]+\\})"
            },
            {
              "name": "constant.other.placeholder.zymbol",
              "match": "\\{[a-zA-Z_][a-zA-Z0-9_]*\\}"
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.zymbol",
          "match": "'([^'\\\\]|\\\\(n|t|\"|'|\\\\|u\\{[0-9A-Fa-f]+\\}))'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.scientific.zymbol",
          "match": "\\b[0-9]+\\.[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.float.zymbol",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.scientific.zymbol",
          "match": "\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.zymbol",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.zymbol",
          "match": "#[01]\\b"
        }
      ]
    },
    "control-flow": {
      "patterns": [
        {
          "name": "keyword.control.conditional.zymbol",
          "match": "\\?\\?(?!\\s)"
        },
        {
          "name": "keyword.control.conditional.zymbol",
          "match": "_\\?(?!\\s)"
        },
        {
          "name": "keyword.control.conditional.zymbol",
          "match": "(?<!\\w)\\?(?!\\?)"
        },
        {
          "name": "keyword.control.else.zymbol",
          "match": "(?<!_)_(?![\\?\\w])"
        },
        {
          "name": "keyword.control.loop.break.zymbol",
          "match": "@!"
        },
        {
          "name": "keyword.control.loop.continue.zymbol",
          "match": "@>"
        },
        {
          "name": "keyword.control.loop.zymbol",
          "match": "@(?![!>])"
        }
      ]
    },
    "io-operators": {
      "patterns": [
        {
          "name": "keyword.operator.output.zymbol",
          "match": ">>"
        },
        {
          "name": "keyword.operator.input.zymbol",
          "match": "<<"
        },
        {
          "name": "constant.character.escape.newline.zymbol",
          "match": "¶|\\\\\\\\(?!\\s)"
        }
      ]
    },
    "function-operators": {
      "patterns": [
        {
          "name": "keyword.operator.return-output.zymbol",
          "match": "<~"
        },
        {
          "name": "storage.type.function.arrow.zymbol",
          "match": "->"
        }
      ]
    },
    "collection-operators": {
      "patterns": [
        {
          "name": "keyword.operator.collection.zymbol",
          "match": "\\$[#\\+\\-~\\*\\/\\^<>]"
        }
      ]
    },
    "module-operators": {
      "patterns": [
        {
          "name": "keyword.control.import.zymbol",
          "match": "<#"
        },
        {
          "name": "keyword.control.module.zymbol",
          "match": "^#(?!\\s*[01]\\b)"
        },
        {
          "name": "keyword.operator.namespace.zymbol",
          "match": "::"
        }
      ]
    },
    "data-operators": {
      "patterns": [
        {
          "name": "keyword.operator.metadata.zymbol",
          "match": "#\\?"
        },
        {
          "name": "keyword.operator.numeric-eval.zymbol",
          "begin": "#\\|",
          "end": "\\|",
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "format-expressions": {
      "patterns": [
        {
          "name": "keyword.operator.format.scientific.zymbol",
          "begin": "\\be\\|",
          "end": "\\|",
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "name": "keyword.operator.format.comma.zymbol",
          "begin": "\\bc\\|",
          "end": "\\|",
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "name": "keyword.operator.base-conversion.binary.zymbol",
          "begin": "0b\\|",
          "end": "\\|",
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "name": "keyword.operator.base-conversion.octal.zymbol",
          "begin": "0o\\|",
          "end": "\\|",
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "name": "keyword.operator.base-conversion.decimal.zymbol",
          "begin": "0d\\|",
          "end": "\\|",
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "name": "keyword.operator.base-conversion.hex.zymbol",
          "begin": "0x\\|",
          "end": "\\|",
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "base-literals": {
      "patterns": [
        {
          "name": "constant.numeric.base.binary.zymbol",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.base.octal.zymbol",
          "match": "\\b0o[0-7]+\\b"
        },
        {
          "name": "constant.numeric.base.decimal.zymbol",
          "match": "\\b0d[0-9]+\\b"
        },
        {
          "name": "constant.numeric.base.hexadecimal.zymbol",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.zymbol",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.range.zymbol",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.logical.zymbol",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.comparison.zymbol",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.zymbol",
          "match": "\\*\\*|\\+|\\-|\\*|\\/|%"
        },
        {
          "name": "keyword.operator.member-access.zymbol",
          "match": "\\."
        },
        {
          "name": "keyword.operator.assignment.zymbol",
          "match": "="
        },
        {
          "name": "punctuation.separator.comma.zymbol",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.zymbol",
          "match": ":"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.zymbol",
          "match": "[a-zA-Z_\\u00C0-\\u024F\\u1E00-\\u1EFF\\u0370-\\u03FF\\u0400-\\u04FF\\u0600-\\u06FF\\u0900-\\u097F\\u4E00-\\u9FFF\\u3040-\\u309F\\u30A0-\\u30FF\\uAC00-\\uD7AF\\uD800-\\uDFFF][a-zA-Z0-9_\\u00C0-\\u024F\\u1E00-\\u1EFF\\u0370-\\u03FF\\u0400-\\u04FF\\u0600-\\u06FF\\u0900-\\u097F\\u4E00-\\u9FFF\\u3040-\\u309F\\u30A0-\\u30FF\\uAC00-\\uD7AF\\uD800-\\uDFFF]*"
        }
      ]
    }
  }
}
